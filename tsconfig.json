{
  "compilerOptions": {
    "outDir": "dist/",
    "sourceMap": true,
    "declaration": true,
    "noImplicitAny": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2018",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2018"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}

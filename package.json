{
  "name": "react-painter",
  "version": "1.0.1",
  "description": "A React component for drawing in a canvas",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "cd demo && npm run dev",
    "demo:build": "cd demo && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aml2610/react-painter.git"
  },
  "keywords": [
    "react",
    "canvas",
    "drawing"
  ],
  "author": {
    "name": "Andrei-Marius Longhin",
    "email": "andrei.longhin1@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aml2610/react-painter/issues"
  },
  "homepage": "https://github.com/aml2610/react-painter#readme",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "core-js": "^2.5.4",
    "eslint": "^8.57.0",
    "jest-canvas-mock": "^2.5.0",
    "jsdom": "^24.0.0",
    "prettier": "^1.19.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 90
  }
}
